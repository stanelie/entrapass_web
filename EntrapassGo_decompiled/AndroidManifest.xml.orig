    <application android:allowBackup="false" android:appComponentFactory="androidx.core.app.CoreComponentFactory" android:extractNativeLibs="false" android:icon="@drawable/icon_lancher" android:label="@string/app_name" android:name="com.Kantech.EntrapassGo.GlobalApplication" android:supportsRtl="true" android:theme="@style/AppTheme.BaseLight" android:usesCleartextTraffic="true">
